// Штукатурка PRO — схема базы данных
// Запуск: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
  FOREMAN
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  DONE
}

enum RoomStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum PhotoType {
  BEFORE
  AFTER
  PROCESS
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum DocumentType {
  CONTRACT
  KS2
  KS3
  WARRANTY
}

enum NotificationChannel {
  PUSH
  EMAIL
  TELEGRAM
}

model User {
  id            String    @id @default(cuid())
  phone         String    @unique
  email         String?   @unique
  passwordHash  String
  name          String
  role          Role      @default(CLIENT)
  telegramChatId String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())

  projectsAsClient  Project[] @relation("ClientProjects")
  projectsAsForeman Project[] @relation("ForemanProjects")
  reports           Report[]
  messages          Message[]
  notifications     Notification[]
  plasterMixes      PlasterMix[]
}

model Project {
  id             String        @id @default(cuid())
  clientId       String
  client         User          @relation("ClientProjects", fields: [clientId], references: [id])
  foremanId      String?
  foreman        User?         @relation("ForemanProjects", fields: [foremanId], references: [id])
  address        String
  area           Float
  roomsCount     Int
  floorPlanUrl   String?
  status         ProjectStatus @default(ACTIVE)
  startDate      DateTime      @default(now())
  plannedEndDate DateTime?
  createdAt      DateTime      @default(now())

  rooms           Room[]
  stages          Stage[]
  reports         Report[]
  projectMaterials ProjectMaterial[]
  estimateItems   EstimateItem[]
  estimateSnapshots EstimateSnapshot[]
  measureSquareImports MeasureSquareImport[]
  laborCosts      LaborCost[]
  camera          Camera?
  reviews         Review[]
  documents       Document[]
  payments        Payment[]
  messages        Message[]
  aiSummaries     AISummary[]
}

model Room {
  id              String     @id @default(cuid())
  projectId       String
  project         Project    @relation(fields: [projectId], references: [id])
  name            String
  area            Float      // общая площадь под штукатурку (стены+потолок) — используется в прогрессе проекта
  status          RoomStatus @default(PENDING)
  progressPercent Int        @default(0)
  planCoordX      Float?
  planCoordY      Float?

  // Параметры комнаты для калькулятора материалов
  wallArea            Float?   // квадратура стен под штукатурку
  floorArea           Float?   // квадратура пола (справочно)
  windowArea          Float?   // площадь окон (вычитается из площади стен)
  perimeter           Float?   // периметр стен — нужен для маяков/сетки
  height              Float?   @default(2.7) // высота потолков, м
  slopeLinearMeters   Float?   // погонные метры откосов (окна/двери)
  meshJointsMeters     Float?   // погонные метры стыков под армирующую сетку
  thicknessMm         Int?     @default(15) // выбранная толщина слоя штукатурки
  selectedMixId       String?
  selectedMix         PlasterMix? @relation(fields: [selectedMixId], references: [id])
  selectedPrimerId    String?
  selectedPrimer      Primer?     @relation(fields: [selectedPrimerId], references: [id])

  // Данные LiDAR-скана (из собственного iOS-модуля на базе Apple RoomPlan)
  scanSource      String?    // "ROOMPLAN_NATIVE" | "MANUAL" | null
  scanWallsJson   Json?      // полигон стен: [{x,y}, ...] в метрах, для авто-построения плана
  scanCeilingHeight Float?
  scannedAt       DateTime?

  reports         Report[]
  photos          Photo[]
  qualityChecklists QualityChecklist[]
}

model Stage {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id])
  name          String
  order         Int
  plannedStart  DateTime?
  plannedEnd    DateTime?
  status        RoomStatus @default(PENDING)

  qualityChecklists QualityChecklist[]
  reviews           Review[]
}

model Report {
  id                  String   @id @default(cuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id])
  roomId              String
  room                Room     @relation(fields: [roomId], references: [id])
  authorId            String
  author               User    @relation(fields: [authorId], references: [id])
  date                DateTime @default(now())
  wallsArea           Float    @default(0)
  ceilingArea         Float    @default(0)
  waterShutOff        Boolean  @default(false)
  doorsClosed         Boolean  @default(false)
  furnitureProtected  Boolean  @default(false)
  comment             String?

  photos          Photo[]
  materialsUsed   ReportMaterial[]
}

model Material {
  id            String   @id @default(cuid())
  name          String
  unit          String
  pricePerUnit  Float?   // цена для клиента (в смете)
  costPerUnit   Float?   // закупочная цена компании — видна только бригадиру/админу

  reportMaterials  ReportMaterial[]
  projectMaterials ProjectMaterial[]
}

// Прочие расходы по объекту (зарплата бригады, транспорт, аренда техники и т.д.)
// Видно только FOREMAN/ADMIN — это внутренняя экономика, не для клиента.
model LaborCost {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  description String
  amount      Float
  date        DateTime @default(now())
  addedById   String
}

// Камера на объекте, стримящая через Mux (или любой RTMP-совместимый провайдер).
// streamKey — секрет для устройства-камеры, никогда не отдаётся клиенту.
// playbackId — публичный идентификатор для встраивания плеера клиенту.
model Camera {
  id          String   @id @default(cuid())
  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id])
  provider    String   @default("MUX")
  streamKey   String   // секретно, только для устройства камеры
  playbackId  String   // публично, для плеера клиента
  status      String   @default("IDLE") // IDLE | ACTIVE | ERRORED
  createdAt   DateTime @default(now())
}

// Смеси для механизированной штукатурки — база + пользовательские.
// Расход задаётся отдельно на 4 стандартные толщины слоя (кг/м²).
model PlasterMix {
  id                String   @id @default(cuid())
  name              String   // "Jatbay", "Magma", "Volma", "Knauf MP 75" или своя
  brand             String?
  consumption10mm   Float    // кг/м² при толщине 10мм
  consumption15mm   Float    // кг/м² при толщине 15мм
  consumption20mm   Float    // кг/м² при толщине 20мм
  consumption25mm   Float    // кг/м² при толщине 25мм
  bagWeightKg       Float    @default(30)
  pricePerBag       Float?
  isCustom          Boolean  @default(false)
  createdById       String?
  createdBy         User?    @relation(fields: [createdById], references: [id])
  createdAt         DateTime @default(now())

  rooms             Room[]
}

// Грунтовки — расход задаётся одним значением на м² (не зависит от толщины штукатурки).
model Primer {
  id                String   @id @default(cuid())
  name              String   // "Бетоноконтакт", "Knauf Tiefengrund", "Mittelgrund"
  consumptionPerM2  Float    // кг или л на м²
  unit              String   @default("л") // "л" | "кг"
  containerVolume   Float    @default(10) // объём одной канистры/ведра
  pricePerContainer Float?

  rooms             Room[]
}

// Снимок полной сметы объекта на определённую дату — история расчётов.
model EstimateSnapshot {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  totalCost     Float
  breakdownJson Json     // построчная разбивка на момент сохранения
  createdById   String?
  createdAt     DateTime @default(now())
}

model ReportMaterial {
  id         String   @id @default(cuid())
  reportId   String
  report     Report   @relation(fields: [reportId], references: [id])
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Float
}

model ProjectMaterial {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  materialId String
  material   Material @relation(fields: [materialId], references: [id])
  ordered    Float    @default(0)
  used       Float    @default(0)
  remaining  Float    @default(0)
}

// Смета, полученная из MeasureSquare (или введённая менеджером вручную)
model EstimateItem {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  roomName    String?
  description String
  quantity    Float
  unit        String
  unitPrice   Float
  total       Float
  source      String   @default("MANUAL") // "MEASURESQUARE" | "MANUAL"
  createdAt   DateTime @default(now())
}

// Сырые данные, пришедшие от MeasureSquare по конкретному проекту-скану,
// для отладки и повторной обработки без нового запроса к их API.
model MeasureSquareImport {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  msProjectId    String   // ID проекта в системе MeasureSquare
  floorplanUrl   String?
  rawPayload     Json
  importedAt     DateTime @default(now())
}

model Photo {
  id        String    @id @default(cuid())
  reportId  String?
  report    Report?   @relation(fields: [reportId], references: [id])
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id])
  url       String
  type      PhotoType @default(PROCESS)
  geoLat    Float?
  geoLng    Float?
  takenAt   DateTime  @default(now())
}

model QualityChecklist {
  id         String   @id @default(cuid())
  stageId    String
  stage      Stage    @relation(fields: [stageId], references: [id])
  roomId     String
  room       Room     @relation(fields: [roomId], references: [id])
  criteria   Json
  passed     Boolean  @default(false)
  checkedBy  String?
  checkedAt  DateTime?
}

model Review {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  stageId   String?
  stage     Stage?   @relation(fields: [stageId], references: [id])
  authorId  String?
  rating    Int
  comment   String?
  published Boolean  @default(false) // модерация: попадает на публичную страницу только после одобрения ADMIN
  createdAt DateTime @default(now())
}

// Заявка от потенциального клиента на просмотр объекта/консультацию —
// заполняется на публичном сайте, без регистрации.
model Lead {
  id             String   @id @default(cuid())
  name           String
  phone          String
  address        String?
  preferredDate  DateTime?
  comment        String?
  status         String   @default("NEW") // NEW | CONTACTED | SCHEDULED | CLOSED
  createdAt      DateTime @default(now())
}

model Document {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id])
  type      DocumentType
  fileUrl   String
  signedAt  DateTime?
  createdAt DateTime     @default(now())
}

model Payment {
  id         String        @id @default(cuid())
  projectId  String
  project    Project       @relation(fields: [projectId], references: [id])
  amount     Float
  dueDate    DateTime
  paidAt     DateTime?
  status     PaymentStatus @default(PENDING)
  invoiceUrl String?
}

model Message {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  senderId       String
  sender         User     @relation(fields: [senderId], references: [id])
  text           String?
  attachmentUrl  String?
  createdAt      DateTime @default(now())
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  type      String
  payload   Json
  channel   NotificationChannel
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime            @default(now())
}

model AISummary {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  periodType  String
  text        String
  generatedAt DateTime @default(now())
}
